# ==========================================
# Car Dealership Inventory System Config Example
# ==========================================

# Port configuration
PORT=5000

# PostgreSQL Database Connection
SPRING_DATASOURCE_URL=jdbc:postgresql://your-db-host:5432/your-db-name
SPRING_DATASOURCE_USERNAME=your-db-username
SPRING_DATASOURCE_PASSWORD=your-db-password

# JWT Authentication Secret Key (256-bit Hex Key)
JWT_SECRET=your-jwt-secret-key-at-least-256-bits

# Initial Seeded Admin User Credentials
ADMIN_EMAIL=admin@yourdealership.com
ADMIN_PASSWORD=YourSecureAdminPassword!
